# APP_SECRET необязателен. Если не задан, сервер автоматически сгенерирует случайный 32-байтный ключ
# и сохранит его в data/secret.key для повторного использования.
APP_SECRET=
PUBLIC_BASE_URL=https://your-domain.example
CORS_ORIGIN=https://your-domain.example
MAX_UPLOAD_MB=200
AI_TIMEOUT_MS=180000
AI_MAX_TOKENS=8000
ENABLE_DEMO_LOGIN=true

# Интеграция с ИИ-агентами Timeweb Cloud (meweb.cloud)
# Замените на ваш JWT токен и ID созданного агента
TIMEWEB_API_KEY=
TIMEWEB_AGENT_ID=

# YouTube Data API v3 (Google Cloud Console)
# Создай OAuth 2.0 credentials (тип: Web application), разреши redirect URI:
# https://your-domain.example/api/auth/youtube/callback
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# Настройки демонстрационного и клиентского входа
ENABLE_DEMO_LOGIN=true
DEMO_EMAIL=kubik
DEMO_PASSWORD=kubik

CLIENT_DEMO_EMAIL=client
CLIENT_DEMO_PASSWORD=client123
CLIENT_SHARED_WORKSPACE=true
CLIENT_DAILY_GENERATION_LIMIT=5

