{
  "name": "content-factory-backend",
  "version": "1.0.0",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "test:smoke": "playwright test",
    "test:smoke:headed": "playwright test --headed",
    "test:smoke:ui": "playwright test --ui",
    "check:pa11y": "start-server-and-test start http://127.0.0.1:3000 \"pa11y http://127.0.0.1:3000 --standard WCAG2AA\"",
    "check:lighthouse": "npx --yes @lhci/cli autorun --config=./lighthouserc.json"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "googleapis": "^172.0.0",
    "helmet": "^8.2.0",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.38.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "pa11y": "^9.1.1",
    "start-server-and-test": "^3.0.5"
  }
}
